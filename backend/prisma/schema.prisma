generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  ADMIN
}

model User {
  id                 String             @id @default(cuid())
  username           String             @unique
  passwordHash       String
  role               UserRole           @default(CUSTOMER)
  email              String?            @unique
  createdAt          DateTime           @default(now())
  orders             Order[]
  notificationReads  AdminNotificationRead[]
}

// ---------------------------------------------------------
// NEW MODELS: CLOTHING ITEMS & INVENTORY
// ---------------------------------------------------------

// 1. Clothing Types
enum ClothingType {
  UNSTITCHED
  THREE_PC   // 3pc
  TWO_PC     // 2pc
  SEPARATE
}

// 2. The Main Product
model Product {
  id          String       @id @default(cuid())
  name        String
  description String?      @db.Text
  type        ClothingType
  isActive    Boolean      @default(true) 
  
  variants    ProductVariant[]
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// 3. Product Variants
model ProductVariant {
  id            String         @id @default(cuid())
  productId     String
  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku           String?        @unique // Optional: Stock Keeping Unit

  salePrice     Decimal
  purchasePrice Decimal?

  // Cached stock value for fast queries.
  // It gets updated whenever a StockMove is created.
  stockQty      Int            @default(0)

  images        ProductImage[]
  stockMoves    StockMove[]
  heroSlides    HomeHeroSlide[]
  orderLines    OrderLine[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

enum OrderStatus {
  PENDING
  SHIPPED
  DELIVERED
}

enum OrderPaymentMethod {
  COD
  ONLINE
}

model Order {
  id              String             @id @default(cuid())
  orderNumber     Int                @unique @default(autoincrement())
  customerName    String
  phone           String
  shippingAddress String             @db.Text
  city            String
  payment         OrderPaymentMethod
  status          OrderStatus        @default(PENDING)
  subtotal        Decimal            @db.Decimal(12, 2)
  total           Decimal            @db.Decimal(12, 2)
  userId          String?
  user            User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  lines           OrderLine[]
  notifications   AdminNotification[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([createdAt])
}

enum NotificationType {
  ORDER_PLACED
}

/** Renamed from `Notification` so Prisma Client exposes `adminNotification` (plain `notification` is omitted). */
model AdminNotification {
  id        String                  @id @default(cuid())
  type      NotificationType
  title     String
  body      String?                 @db.Text
  orderId   String?
  order     Order?                  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  reads     AdminNotificationRead[]
  createdAt DateTime                @default(now())

  @@index([createdAt])
  @@map("Notification")
}

model AdminNotificationRead {
  notificationId String
  notification   AdminNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt         DateTime          @default(now())

  @@id([notificationId, userId])
  @@map("NotificationRead")
}

model OrderLine {
  id               String         @id @default(cuid())
  orderId          String
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariantId String
  variant          ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)
  productName      String
  productType      String
  sku              String?
  qty              Int
  unitPrice        Decimal        @db.Decimal(12, 2)
  lineTotal        Decimal        @db.Decimal(12, 2)
}

enum HomeHeroTheme {
  LIGHT
  DARK
}

model HomeHeroSlide {
  id                  String           @id @default(cuid())
  sortOrder           Int              @default(0)
  isActive            Boolean          @default(true)
  theme               HomeHeroTheme
  usePrimaryHeading   Boolean          @default(false)
  eyebrow             String?
  title               String?
  description         String?          @db.Text
  productVariantId    String?
  productVariant      ProductVariant?  @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 4. Variant Images
model ProductImage {
  id               String         @id @default(cuid())
  productVariantId String
  variant          ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  
  url              String         // Local server path, e.g., /uploads/images/abc.jpg
  order            Int            @default(0) // To control which image is main (order = 0)
  
  createdAt        DateTime       @default(now())
}

// 5. Stock Moves for History & Accountability
enum StockMoveType {
  IN         // e.g., New stock received
  OUT        // e.g., Sold to customer
  ADJUSTMENT // e.g., Defective, manual count correction
}

model StockMove {
  id               String         @id @default(cuid())
  productVariantId String
  variant          ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  
  type             StockMoveType
  quantity         Int            // Positive number representing the amount moved
  notes            String?        // Reason for move (e.g., "Restock", "Damage")

  createdAt        DateTime       @default(now())
}
