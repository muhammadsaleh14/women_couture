{
  "openapi": "3.0.0",
  "info": {
    "title": "Women Couture API",
    "version": "0.1.0",
    "description": "REST API for Women Couture"
  },
  "servers": [
    {
      "url": "http://localhost:3000/api/v1"
    }
  ],
  "components": {
    "schemas": {
      "HomeHeroTheme": {
        "type": "string",
        "enum": [
          "LIGHT",
          "DARK"
        ]
      },
      "HomeHeroSlideResolved": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "theme": {
            "type": "string",
            "enum": [
              "LIGHT",
              "DARK"
            ]
          },
          "usePrimaryHeading": {
            "type": "boolean"
          },
          "eyebrow": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "productId": {
            "type": "string",
            "nullable": true
          },
          "variantId": {
            "type": "string",
            "nullable": true
          },
          "imageUrl": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "id",
          "theme",
          "usePrimaryHeading",
          "eyebrow",
          "title",
          "description",
          "productId",
          "variantId",
          "imageUrl"
        ]
      },
      "HomeHeroSlideRecord": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "sortOrder": {
            "type": "integer"
          },
          "isActive": {
            "type": "boolean"
          },
          "theme": {
            "type": "string",
            "enum": [
              "LIGHT",
              "DARK"
            ]
          },
          "usePrimaryHeading": {
            "type": "boolean"
          },
          "eyebrow": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "productVariantId": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "sortOrder",
          "isActive",
          "theme",
          "usePrimaryHeading",
          "eyebrow",
          "title",
          "description",
          "productVariantId",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateHomeHeroSlideBody": {
        "type": "object",
        "properties": {
          "sortOrder": {
            "type": "integer"
          },
          "isActive": {
            "type": "boolean"
          },
          "theme": {
            "type": "string",
            "enum": [
              "LIGHT",
              "DARK"
            ]
          },
          "usePrimaryHeading": {
            "type": "boolean"
          },
          "eyebrow": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "productVariantId": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "theme"
        ]
      },
      "UpdateHomeHeroSlideBody": {
        "type": "object",
        "properties": {
          "sortOrder": {
            "type": "integer"
          },
          "isActive": {
            "type": "boolean"
          },
          "theme": {
            "type": "string",
            "enum": [
              "LIGHT",
              "DARK"
            ]
          },
          "usePrimaryHeading": {
            "type": "boolean"
          },
          "eyebrow": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "productVariantId": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "ReorderHomeHeroSlidesBody": {
        "type": "object",
        "properties": {
          "orderedIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          }
        },
        "required": [
          "orderedIds"
        ]
      },
      "ClothingType": {
        "type": "string",
        "enum": [
          "UNSTITCHED",
          "THREE_PC",
          "TWO_PC",
          "SEPARATE"
        ]
      },
      "ProductBase": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "type": {
            "type": "string",
            "enum": [
              "UNSTITCHED",
              "THREE_PC",
              "TWO_PC",
              "SEPARATE"
            ]
          },
          "isActive": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "name",
          "description",
          "type",
          "isActive",
          "createdAt",
          "updatedAt"
        ]
      },
      "ProductImage": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "order": {
            "type": "integer"
          }
        },
        "required": [
          "id",
          "url",
          "order"
        ]
      },
      "ProductVariant": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "productId": {
            "type": "string"
          },
          "sku": {
            "type": "string",
            "nullable": true
          },
          "salePrice": {
            "type": "number",
            "nullable": true
          },
          "purchasePrice": {
            "type": "number",
            "nullable": true
          },
          "stockQty": {
            "type": "integer"
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProductImage"
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "productId",
          "sku",
          "salePrice",
          "purchasePrice",
          "stockQty",
          "createdAt",
          "updatedAt"
        ]
      },
      "ProductWithVariants": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ProductBase"
          },
          {
            "type": "object",
            "properties": {
              "variants": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ProductVariant"
                }
              }
            },
            "required": [
              "variants"
            ]
          }
        ]
      },
      "CreateProductBody": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "UNSTITCHED",
              "THREE_PC",
              "TWO_PC",
              "SEPARATE"
            ]
          },
          "variants": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "sku": {
                  "type": "string"
                },
                "salePrice": {
                  "type": "number",
                  "minimum": 0,
                  "exclusiveMinimum": true
                },
                "purchasePrice": {
                  "type": "number",
                  "minimum": 0,
                  "exclusiveMinimum": true
                }
              },
              "required": [
                "salePrice"
              ]
            }
          }
        },
        "required": [
          "name",
          "type"
        ]
      },
      "CreateVariantBody": {
        "type": "object",
        "properties": {
          "sku": {
            "type": "string"
          },
          "salePrice": {
            "type": "number",
            "minimum": 0,
            "exclusiveMinimum": true
          },
          "purchasePrice": {
            "type": "number",
            "minimum": 0,
            "exclusiveMinimum": true
          }
        },
        "required": [
          "salePrice"
        ]
      },
      "AdjustStockBody": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "IN",
              "OUT",
              "ADJUSTMENT"
            ]
          },
          "quantity": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": true
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "type",
          "quantity"
        ]
      },
      "UpdateProductBody": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "UNSTITCHED",
              "THREE_PC",
              "TWO_PC",
              "SEPARATE"
            ]
          },
          "isActive": {
            "type": "boolean"
          }
        }
      },
      "SaveProductBody": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "UNSTITCHED",
              "THREE_PC",
              "TWO_PC",
              "SEPARATE"
            ]
          },
          "variants": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "sku": {
                  "type": "string"
                },
                "salePrice": {
                  "type": "number",
                  "minimum": 0
                },
                "purchasePrice": {
                  "type": "number",
                  "nullable": true,
                  "minimum": 0
                },
                "existingImageIds": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "salePrice"
              ]
            },
            "minItems": 1
          }
        },
        "required": [
          "name",
          "type",
          "variants"
        ]
      },
      "ProductVariantParams": {
        "type": "object",
        "properties": {
          "variantId": {
            "type": "string"
          }
        },
        "required": [
          "variantId"
        ]
      },
      "ProductParams": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string"
          }
        },
        "required": [
          "productId"
        ]
      },
      "ProductQuery": {
        "type": "object",
        "properties": {
          "skip": {
            "type": "integer",
            "nullable": true,
            "minimum": 0,
            "default": 0
          },
          "take": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 20
          },
          "isActive": {
            "type": "string",
            "enum": [
              "true",
              "false"
            ]
          }
        }
      },
      "UpdateVariantBody": {
        "type": "object",
        "properties": {
          "sku": {
            "type": "string"
          },
          "salePrice": {
            "type": "number",
            "minimum": 0,
            "exclusiveMinimum": true
          },
          "purchasePrice": {
            "type": "number",
            "minimum": 0,
            "exclusiveMinimum": true
          }
        }
      },
      "OrderPayment": {
        "type": "string",
        "enum": [
          "cod",
          "online"
        ]
      },
      "OrderStatusPublic": {
        "type": "string",
        "enum": [
          "pending",
          "shipped",
          "delivered"
        ]
      },
      "OrderLinePublic": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "productName": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "sku": {
            "type": "string",
            "nullable": true
          },
          "qty": {
            "type": "integer"
          },
          "unitPrice": {
            "type": "number"
          },
          "lineTotal": {
            "type": "number"
          }
        },
        "required": [
          "id",
          "productName",
          "type",
          "sku",
          "qty",
          "unitPrice",
          "lineTotal"
        ]
      },
      "OrderPublic": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "orderNumber": {
            "type": "integer"
          },
          "placedAt": {
            "type": "string",
            "format": "date-time"
          },
          "customerName": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "shippingAddress": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "payment": {
            "type": "string",
            "enum": [
              "cod",
              "online"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "shipped",
              "delivered"
            ]
          },
          "subtotal": {
            "type": "number"
          },
          "total": {
            "type": "number"
          },
          "lines": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderLinePublic"
            }
          }
        },
        "required": [
          "id",
          "orderNumber",
          "placedAt",
          "customerName",
          "phone",
          "shippingAddress",
          "city",
          "payment",
          "status",
          "subtotal",
          "total",
          "lines"
        ]
      },
      "CreateOrderBody": {
        "type": "object",
        "properties": {
          "customerName": {
            "type": "string",
            "minLength": 1
          },
          "phone": {
            "type": "string",
            "minLength": 1
          },
          "shippingAddress": {
            "type": "string",
            "minLength": 1
          },
          "city": {
            "type": "string",
            "minLength": 1
          },
          "payment": {
            "type": "string",
            "enum": [
              "cod",
              "online"
            ]
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "variantId": {
                  "type": "string",
                  "minLength": 1
                },
                "qty": {
                  "type": "integer",
                  "minimum": 0,
                  "exclusiveMinimum": true
                }
              },
              "required": [
                "variantId",
                "qty"
              ]
            },
            "minItems": 1
          }
        },
        "required": [
          "customerName",
          "phone",
          "shippingAddress",
          "city",
          "payment",
          "items"
        ]
      },
      "UpdateOrderBody": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "shipped",
              "delivered"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "AuthTokenResponse": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/UserPublic"
          }
        },
        "required": [
          "accessToken",
          "user"
        ]
      },
      "UserPublic": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "CUSTOMER",
              "ADMIN"
            ]
          }
        },
        "required": [
          "id",
          "username",
          "role"
        ]
      },
      "RegisterBody": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "minLength": 3,
            "maxLength": 32
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "maxLength": 128
          }
        },
        "required": [
          "username",
          "password"
        ]
      },
      "LoginBody": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "minLength": 1,
            "maxLength": 32
          },
          "password": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        },
        "required": [
          "username",
          "password"
        ]
      },
      "EchoResponse": {
        "type": "object",
        "properties": {
          "echo": {
            "type": "string"
          }
        },
        "required": [
          "echo"
        ]
      },
      "EchoBody": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "message"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/auth/register": {
      "post": {
        "summary": "Register (customer only)",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterBody"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthTokenResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Login",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthTokenResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "summary": "Current user (send Authorization: Bearer token)",
        "tags": [
          "Auth"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserPublic"
                }
              }
            }
          }
        }
      }
    },
    "/echo": {
      "post": {
        "summary": "Echo message",
        "tags": [
          "Example"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EchoBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Echoed message",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EchoResponse"
                }
              }
            }
          }
        }
      }
    },
    "/home-hero-slides": {
      "get": {
        "summary": "List active home hero slides (resolved for storefront)",
        "tags": [
          "HomeHero"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/HomeHeroSlideResolved"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create home hero slide",
        "tags": [
          "HomeHero"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateHomeHeroSlideBody"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HomeHeroSlideRecord"
                }
              }
            }
          }
        }
      }
    },
    "/home-hero-slides/manage": {
      "get": {
        "summary": "List all home hero slides (management)",
        "tags": [
          "HomeHero"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/HomeHeroSlideRecord"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/home-hero-slides/reorder": {
      "patch": {
        "summary": "Reorder home hero slides",
        "tags": [
          "HomeHero"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReorderHomeHeroSlidesBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/HomeHeroSlideRecord"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/home-hero-slides/{slideId}": {
      "patch": {
        "summary": "Update home hero slide",
        "tags": [
          "HomeHero"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "slideId",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateHomeHeroSlideBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HomeHeroSlideRecord"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete home hero slide",
        "tags": [
